{
  "name": "martabs",
  "version": "0.9.8",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "test:e2e": "npx playwright test",
    "test:e2e:chrome": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:update-screenshots": "npx playwright test --update-snapshots",
    "build": "node scripts/build.mjs",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "package": "node scripts/package.mjs",
    "i18n:check": "node scripts/i18n-maintain.mjs --check",
    "i18n:maintain": "node scripts/i18n-maintain.mjs --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright-webextext": "^0.0.5",
    "tslib": "^2.8.1"
  }
}