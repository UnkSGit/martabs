{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.9.8",
  "description": "__MSG_extensionDescription__",
  "default_locale": "es",
  "author": "UnkSGit",
  "homepage_url": "https://github.com/UnkSGit/martabs",
  "icons": {
    "128": "images/icon-128.png"
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "optional_permissions": [
    "topSites"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*",
    "<all_urls>"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://nonexistent-dummy-url-to-avoid-playwright-bug.invalid/*"],
      "js": ["shared/dummy.js"]
    }
  ],
  "options_page": "setup/setup.html"
}